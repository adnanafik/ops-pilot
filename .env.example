# ops-pilot environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── LLM provider (pick one) ───────────────────────────────────────────────────

# Option A — Anthropic direct API (default)
# Get an API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Option B — AWS Bedrock
# LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1
# CLAUDE_MODEL=anthropic.claude-sonnet-4-5-20251001-v1:0
#
# AWS credentials — choose one approach:
#   a) Env vars:  AWS_ACCESS_KEY_ID=AKIA...  AWS_SECRET_ACCESS_KEY=...
#   b) Profile:   AWS_PROFILE=my-profile  (from ~/.aws/credentials)
#   c) IAM role:  automatic on EC2 / ECS / Lambda

# Option C — Google Cloud Vertex AI
# LLM_PROVIDER=vertex_ai
# GCP_PROJECT=my-project-123
# GCP_REGION=us-east5
# CLAUDE_MODEL=claude-sonnet-4-5-20251001
#
# GCP credentials (Application Default Credentials) — choose one approach:
#   a) Service account key: GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
#   b) Developer machine:   gcloud auth application-default login
#   c) GCE / GKE / Cloud Run: service account attached to compute — automatic

# ── GitHub ────────────────────────────────────────────────────────────────────

# Classic PAT with `repo` + `workflow` scopes
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ── Slack (pick one) ──────────────────────────────────────────────────────────

# Option A — bot token (recommended): posts to any channel
# Create a Slack app at https://api.slack.com/apps, add chat:write scope
SLACK_BOT_TOKEN=xoxb-...

# Option B — incoming webhook (simpler): single channel only
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Logging ───────────────────────────────────────────────────────────────────

# Controls log verbosity for all agents (default: WARNING — only errors show)
# Set to INFO to see agent start/completion/PR events
# Set to DEBUG to see every LLM call with model + backend type
# LOG_LEVEL=INFO

# ── Optional overrides ────────────────────────────────────────────────────────

# Set to false to run live agents instead of pre-recorded scenarios
DEMO_MODE=true

# Override the default Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# Path to a custom config file (default: ops-pilot.yml in current directory)
# OPS_PILOT_CONFIG=/path/to/ops-pilot.yml
