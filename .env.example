# ops-pilot environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub ────────────────────────────────────────────────────────────────────

# Classic PAT with `repo` + `workflow` scopes
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ── Slack (pick one) ──────────────────────────────────────────────────────────

# Option A — bot token (recommended): posts to any channel
# Create a Slack app at https://api.slack.com/apps, add chat:write scope
SLACK_BOT_TOKEN=xoxb-...

# Option B — incoming webhook (simpler): single channel only
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Optional overrides ────────────────────────────────────────────────────────

# Set to false to run live agents instead of pre-recorded scenarios
DEMO_MODE=true

# Override the default Claude model (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# Path to a custom config file (default: ops-pilot.yml in current directory)
# OPS_PILOT_CONFIG=/path/to/ops-pilot.yml
